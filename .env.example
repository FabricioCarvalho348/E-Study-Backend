# Copy this file to .env and adjust values for your machine.
# PowerShell: Copy-Item .env.example .env

ASPNETCORE_ENVIRONMENT=Development

# PostgreSQL (Docker)
POSTGRES_DB=estudy
POSTGRES_USER=estudy
POSTGRES_PASSWORD=CHANGE_ME

# API runtime settings
ConnectionStrings__DefaultConnection=Host=estudy-db;Port=5432;Database=estudy;Username=estudy;Password=CHANGE_ME
BackendUrl=http://localhost:5000
FrontendUrl=http://localhost:5173

# JWT settings
Settings__Jwt__SigningKey=CHANGE_ME_MIN_32_CHARS
Settings__Jwt__Issuer=EStudy.Api
Settings__Jwt__Audience=EStudy.Client
Settings__Jwt__ExpirationTimeMinutes=60

# Sqids settings
Settings__IdCryptographyAlphabet=CHANGE_ME
Settings__Sqids__MinLength=10

# Optional UID/GID values used by Dockerfile build args
APP_UID=1000
APP_GID=1000

