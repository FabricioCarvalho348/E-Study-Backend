{
  "BackendUrl": "http://localhost:5016",
  "FrontendUrl": "http://localhost:5173",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "ConnectionStrings": {
      "DefaultConnection": "${CONNECTION_STRING}"
    },
    "Settings": {
      "IdCryptographyAlphabet": "${ID_CRYPTOGRAPHY_ALPHABET}",
      "Jwt": {
        "SigningKey": "${JWT_SECRET}",
        "ExpirationTimeMinutes": 1000
      }
    }
  }
}
